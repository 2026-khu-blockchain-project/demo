NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# PoolBinaryMarket (Polymarket 유사 풀 배팅). 배포 스크립트가 로컬 배포 시 함께 채웁니다.
# NEXT_PUBLIC_POOL_MARKET_ADDRESS=

# 프로젝트 루트에서 로컬 노드에 배포하면 frontend/.env.local 이 자동으로 갱신됩니다.
#   npm run deploy:local

# MetaMask 네트위치와 맞추기 (배포한 체인과 동일하게)
# Amoy: 80002 / 로컬 Hardhat: 31337
# NEXT_PUBLIC_CHAIN_ID=80002

# Vercel 등에 "오프체인 데모만" 올릴 때 (과제 제출용 Amoy+MetaMask URL에서는 빼기)
# NEXT_PUBLIC_DEMO_ONLY=1
